# ── Copy this file to .env and fill in your secrets ──────────────────────
#
# RULE: Only secrets and deployment-specific overrides belong here.
# All tunable application settings (chunk size, model name, top-k, etc.)
# have sensible defaults in config/settings.py — no .env entry required.

# ── Required: LLM API key ────────────────────────────────────────────────
LLM_KEY=gsk_your_groq_key_here

# ── Optional: Future vector backend credentials ───────────────────────────
# QDRANT_API_KEY=your_qdrant_cloud_key

# ── Optional: Deployment overrides (uncomment to change) ─────────────────
# DEBUG=false
# LOG_LEVEL=INFO

# API server
# API_HOST=0.0.0.0
# API_PORT=8000

# Gradio UI
# GRADIO_HOST=0.0.0.0
# GRADIO_PORT=7860
# GRADIO_SHARE=false

# ── Model / performance overrides (optional) ─────────────────────────────
# Uncomment only if you need to override the defaults in config/settings.py
# GROQ_MODEL_ID=llama-3.3-70b-versatile
# LLM_MAX_TOKENS=4096
# LLM_TEMPERATURE=0.0
# CHUNK_SIZE=800
# TOP_K=5
# SIMILARITY_THRESHOLD=0.30
