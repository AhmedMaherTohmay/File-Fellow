# ── Copy this file to .env and fill in your values ──────────────────────

# LLM
LLM_KEY= g...
LLM_PROVIDER=groq
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024

# Embeddings
EMBEDDING_PROVIDER=sentence_transformers   # sentence_transformers
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# Retrieval
TOP_K=5
SIMILARITY_THRESHOLD=0.25

# Vector store
VECTOR_STORE_BACKEND=chroma   # chroma | faiss

# Server
API_HOST=0.0.0.0
API_PORT=8000
GRADIO_HOST=0.0.0.0
GRADIO_PORT=7860
GRADIO_SHARE=false
